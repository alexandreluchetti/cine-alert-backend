# ================================
# CineAlert Backend — Environment Variables
# ================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Database (SQLite) ─────────────────────────────
# Path where the SQLite database file will be created
DB_PATH=./data/cinealert.db

# ─── JWT ───────────────────────────────────────────
# Must be at least 32 characters long (256-bit strength)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-!!

# ─── IMDB API (RapidAPI) ───────────────────────────
IMDB_API_KEY=4c734d2690msh7f096ff24445fd2p191bd6jsnd0c04fe350c7

# ─── Firebase Cloud Messaging ──────────────────────
# Set to 'true' when you have Firebase credentials configured
FIREBASE_ENABLED=false
# Absolute path to your Firebase Admin SDK JSON credentials file
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ─── Email (for password reset) ────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password

# ─── CORS ──────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
